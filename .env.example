# Provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Config profile
RIA_MODEL_CONFIG_PATH=configs/models/default.toml
RIA_PROVIDER_CONFIG_DIR=configs/providers

# Runtime provider selection
RIA_MODEL_PROVIDER=local
RIA_EMBEDDING_PROVIDER=local
RIA_CHAT_MODEL=local-chat-placeholder
RIA_EMBEDDING_MODEL=local-embedding-placeholder
RIA_TEMPERATURE=0.2
RIA_MAX_TOKENS=512
RIA_REQUEST_TIMEOUT_SECONDS=30
RIA_MAX_RETRIES=2

# Routing
RIA_ROUTING_STRATEGY=single_provider
RIA_ROUTING_ENABLE_FALLBACK=false
RIA_ROUTING_FALLBACK_ORDER=local,openai

# OpenAI
RIA_OPENAI_BASE_URL=https://api.openai.com/v1
RIA_OPENAI_ORGANIZATION=
RIA_OPENAI_PROJECT=

# Claude / Anthropic
RIA_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Gemini
RIA_GEMINI_MODEL=gemini-2.0-flash

# Local placeholder provider
RIA_LOCAL_CHAT_MODEL=local-chat-placeholder
RIA_LOCAL_EMBEDDING_MODEL=local-embedding-placeholder
RIA_LOCAL_EMBEDDING_DIMENSIONS=8
RIA_LOCAL_RESPONSE_PREFIX=[local]

# Retrieval / grounding
RIA_RAG_TOP_K=8
RIA_RAG_SCORE_THRESHOLD=0.25
RIA_RAG_MAX_CONTEXT_DOCS=12
RIA_ENABLE_CITATION_TRACE=true

# Scenario defaults
RIA_DEFAULT_REGION=tokyo-metropolitan
RIA_DEFAULT_POPULATION_ID=tokyo-mvp-v1
RIA_DEFAULT_SAMPLE_SIZE=50
RIA_DEFAULT_SCENARIO_PATH=examples/tokyo-supermarket-launch/scenario.json

# Storage paths
RIA_DATA_DIR=data
RIA_RAW_DATA_DIR=data/raw
RIA_PROCESSED_DATA_DIR=data/processed
RIA_SAMPLE_DATA_DIR=data/sample

# Safety / audit flags
RIA_ALLOWED_USE=research,internal_analysis
RIA_REQUIRE_PROVENANCE=true
RIA_DISABLE_PERSONAL_RECONSTRUCTION=true